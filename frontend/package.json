{
  "name": "kafkito-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "routes:generate": "tsr generate",
    "build": "tsr generate && tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsr generate && tsc -b --noEmit",
    "typecheck": "tsr generate && tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:palette": "bash scripts/check-palette.sh",
    "check:contrast": "node scripts/check-contrast.mjs"
  },
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.87.0",
    "clsx": "^2.1.1",
    "fuse.js": "^7.3.0",
    "i18next": "^26.0.6",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/router-cli": "^1.166.33",
    "@tanstack/router-plugin": "^1.87.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
