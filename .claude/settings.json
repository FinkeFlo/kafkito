{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/agent-team-gate.sh",
            "timeout": 1800,
            "statusMessage": "Running TDD-team gates (test + lint + build per touched domain)"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(go test:*)",
      "Bash(go tool cover:*)",
      "Bash(go vet:*)",
      "Bash(go build:*)",
      "Bash(go mod tidy:*)",
      "Bash(golangci-lint run:*)",
      "Bash(make test:*)",
      "Bash(make lint:*)",
      "Bash(make build:*)",
      "Bash(make worktree-init:*)",
      "Bash(bun run lint:*)",
      "Bash(bun run build:*)",
      "Bash(bun run test:*)",
      "Bash(bun run e2e:*)",
      "Bash(bun run check:palette:*)",
      "Bash(bun run check:strings:*)",
      "Bash(bun run check:tokens:*)",
      "Bash(bun run check:routes:*)",
      "Bash(bun run check:dates:*)",
      "Bash(bun install:*)",
      "Bash(bun pm:*)",
      "Bash(docker compose up:*)",
      "Bash(docker compose down:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose exec:*)",
      "Bash(docker ps:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(git merge-base:*)",
      "Bash(git add:*)",
      "Bash(git restore --staged:*)",
      "Bash(git commit -m:*)",
      "Bash(git checkout -b:*)",
      "Bash(git switch:*)",
      "Bash(git branch:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(scripts/agent-team-gate.sh)",
      "Bash(scripts/agent-team-gate.sh:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)"
    ]
  }
}
